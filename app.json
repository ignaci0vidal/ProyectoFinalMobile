{
  "expo": {
    "name": "proyectoFinalTemp",
    "slug": "proyectoFinalTemp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/mk-logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./src/assets/mk-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#fffaf2"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/mk-logo.png",
        "backgroundColor": "#fffaf2"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./src/assets/favicon.png"
    },
    "plugins": ["expo-audio"]
  }
}
